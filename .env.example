# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role_secret

# --- LLM (xAI Grok now; swap to Anthropic later) ---
LLM_PROVIDER=grok                # grok | anthropic
XAI_API_KEY=xai-xxx
ANTHROPIC_API_KEY=sk-ant-xxx     # optional today; required if LLM_PROVIDER=anthropic

# --- Pinecone ---
PINECONE_API_KEY=pcsk_xxx
PINECONE_INDEX=javis-rag

# --- GitHub ---
GITHUB_TOKEN=github_pat_xxx      # fine-grained PAT, repo read scope

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
